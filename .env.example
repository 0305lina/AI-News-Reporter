# Gemini API (Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

PORT=3001

# 이메일 발송 (택1)

# 방법 A — Resend API (권장, https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=News_AI <onboarding@resend.dev>

# 방법 B — Gmail SMTP (10명 내외 실습용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=News_AI <your_email@gmail.com>
EMAIL_USE_ETHEREAL=false

# 실습: 같은 Wi-Fi에서 다른 PC/폰 접속 허용 (기본 0.0.0.0)
HOST=0.0.0.0
